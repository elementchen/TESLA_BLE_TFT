menu "Tesla BLE Dashboard"

config OLED_SDA_GPIO
    int "OLED SDA GPIO"
    default 41
    range 0 48
    help
        I2C SDA pin for SSD1306 OLED display

config OLED_SCL_GPIO
    int "OLED SCL GPIO"
    default 42
    range 0 48
    help
        I2C SCL pin for SSD1306 OLED display

config OLED_RESET_GPIO
    int "OLED RESET GPIO"
    default -1
    range -1 48
    help
        Reset pin for SSD1306 OLED display (-1 = not connected)

config TESLA_DASH_USE_REAL_CAR_BLE
    bool "Enable Real Car BLE Connection"
    default y
    help
        If checked, the system will use real Tesla BLE NimBLE radio to search and pair with the vehicle. 
        If unchecked, it will play the mock demo script timeline.

config TESLA_DASH_VIN
    string "Tesla Vehicle VIN (for BLE encryption)"
    default "LRWYGCFS2PC792568"
    help
        Your Tesla vehicle's 17-digit VIN code, used to derive the Bluetooth pairing key schema.

endmenu
